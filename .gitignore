# Ignore everything
*

# But track these explicitly
!manifest.json
!styles.css
!main.ts
!package.json
!package-lock.json
!tsconfig.json
!rollup.config.js
!eslint.config.mjs
!src/
!src/**/
!src/**/*.ts
!tests/
!tests/**/
!tests/**/*.ts
!tests/**/*.mjs

# Always ignore OS + logs
!.gitignore
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
