{
  "name": "todoist-board",
  "version": "2.0.2",
  "description": "Obsidian plugin for visualizing Todoist tasks",
  "repository": "https://github.com/propranolol11/todoist-board",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "node --import ./tests/register-loader.mjs --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint:obsidian": "eslint main.ts src/**/*.ts",
    "lint:obsidian:errors": "eslint main.ts src/**/*.ts --quiet",
    "verify": "npm run typecheck && npm run lint:obsidian && npm test && npm run build && npm audit"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.21",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.8.7",
    "rollup": "^4.41.1",
    "rollup-plugin-css-only": "^4.5.2",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "luxon": "^3.7.1"
  }
}
